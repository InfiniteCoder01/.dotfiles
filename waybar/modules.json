{
  "sway/window": {
      "format": ""
  },
  "backlight": {
    "format": "{icon} {percent: >3}%",
    "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
    "on-scroll-down": "brightnessctl -c backlight set 5%-",
    "on-scroll-up": "brightnessctl -c backlight set +5%"
  },
  "pulseaudio": {
    "format": "{icon}  {volume: >3}%",
    "format-bluetooth": "{icon}  {volume: >3}%",
    "format-muted": "яАж muted",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яАе",
      "headset": "яАе",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАз", "яАи"]
    },
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },
  "sway/language": {
      "format": "тМи {}",
      "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
  },

  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
      	"months": "<span color='#bb9af7'><b>{}</b></span>",  // Purple
      	"days": "<span color='#7aa2f7'><b>{}</b></span>",    // Blue
      	"weeks": "<span color='#9ece6a'><b>W{}</b></span>",  // Green
      	"weekdays": "<span color='#e0af68'><b>{}</b></span>",// Yellow
      	"today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>" // Cyan background with dark text
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "{:%a %d %b, %I:%M %p}", //12 hour format
    "format-alt": "яД│ {:%Y-%m-%d яАЧ %H:%M:%S}",
    "interval": 1
  },

  "custom/tray#drawer": {
    "format": "тШ░"
  },
  "group/tray": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 250,
      "transition-left-to-right": false,
    },
    "modules": [ "custom/tray#drawer", "tray" ]
  },
  "network": {
    "format": "тЪа Disabled",
    "format-wifi": "яЗл  WiFi ({signalStrength}%)",
    "format-ethernet": "яГБ  Wired",
    "format-disconnected": "тЪа Disconnected",
    "tooltip-format-wifi": "яЗл  WiFi ({signalStrength}%)",
    "tooltip-format-ethernet": "яГБ  Wired",
    "tooltip-format-disconnected": "тЪа Disconnected",
    "on-click": "kitty -e nmtui"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}   {capacity: >3}%",
    "format-alt": "{icon}   {time}",
    "format-charging": "яЗж {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
}
