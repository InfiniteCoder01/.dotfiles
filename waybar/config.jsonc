{
	"layer": "top",
	"position": "top",
	"height": 30,
	"padding": 0,
	"spacing": 4,
	"modules-left": [
		"sway/window",
		"sway/language",
		"backlight",
		"pulseaudio",
	],
	"modules-center": ["clock"],
	"modules-right": [
		"group/tray",
		"network",
		"battery",
	],
	"include": ["~/.config/waybar/modules.json"],
}
